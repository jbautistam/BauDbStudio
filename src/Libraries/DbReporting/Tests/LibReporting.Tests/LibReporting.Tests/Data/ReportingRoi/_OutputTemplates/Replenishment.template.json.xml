<?xml version="1.0" encoding="utf-8" ?>
<Template Id ="Replenishment">
	<Subtemplate Id="Expressions">
        <![CDATA[
        "expressions": 
        {
            "minimumMultiple": {{[Prefix]minimumMultiple,string,null}},
            "productiveBlock": {{[Prefix]productiveBlock,decimal,null}},
            "originalOrder": {{[Prefix]originalOrder,decimal,null}},
            "originalOrderCost": {{[Prefix]originalOrderCost,decimal,null}},
            "orders": {{[Prefix]orders,decimal,null}},
            "orderCost": {{[Prefix]orderCost,decimal,null}},
            "imminentRupture": {{[Prefix]imminentRupture,decimal,null}},
            "stockOutDay": {{[Prefix]stockOutDay,decimal,null}},
            "ruptureDays": {{[Prefix]ruptureDays,decimal,null}},
            "daysInStore": {{[Prefix]daysInStore,decimal,null}},
            "lastMonthSales": {{[Prefix]lastMonthSales,decimal,null}},
            "salesTwoMonths": {{[Prefix]salesTwoMonths,decimal,null}},
            "salesTwoMonthsOutlier": {{[Prefix]salesTwoMonthsOutlier,decimal,null}},
            "salesSixMonths": {{[Prefix]salesSixMonths,decimal,null}},
            "salesSixMonthsOutlier": {{[Prefix]salesSixMonthsOutlier,decimal,null}},
            "salesProjection": {{[Prefix]salesProjection,decimal,null}},
            "actualStock": {{[Prefix]actualStock,decimal,null}},
            "warehouseStock": {{[Prefix]warehouseStock,decimal,null}},
            "pendingReceptions": {{[Prefix]pendingReceptions,decimal,null}},
            "idealWindow": {{[Prefix]idealWindow,decimal,null}},
            "realWindow": {{[Prefix]realWindow,decimal,null}},
            "availableStock": {{[Prefix]availableStock,decimal,null}},
            "stockCost": {{[Prefix]stockCost,decimal,null}},
            "overstock": {{[Prefix]overstock,decimal,null}},
            "missingStock": {{[Prefix]missingStock,decimal,null}},
            "transferIn": {{[Prefix]transferIn,decimal,null}},
            "transferOut": {{[Prefix]transferOut,decimal,null}},
            "returns": {{[Prefix]returns,decimal,null}},
            "coverage": {{[Prefix]coverage,decimal,null}},
            "promotionValue": {{[Prefix]promotionValue,decimal,null}},
            "forcedWindows": {{[Prefix]forcedWindows,decimal,null}},
            "forcedProductive": {{[Prefix]forcedProductive,decimal,null}},
            "lastDayOfSale": {{[Prefix]lastDayOfSale,datetime,null}},
            "ruptureTwoMonths": {{[Prefix]ruptureTwoMonths,decimal,null}},
            "ruptureSixMonths": {{[Prefix]ruptureSixMonths,decimal,null}},
            "storeBlocks": {{[Prefix]storeBlocks,decimal,null}},
            "globalBlocks": {{[Prefix]globalBlocks,decimal,null}},
            "purchaseOrder": {{[Prefix]purchaseOrder,decimal,null}},
            "salesIndirect2Months": {{[Prefix]salesIndirect2Months,decimal,null}},
            "salesIndirect6Months": {{[Prefix]salesIndirect6Months,decimal,null}},
            "omnichannelIdealStock": {{[Prefix]omnichannelIdealStock,decimal,null}},
            "idealCoverage": {{[Prefix]idealCoverage,decimal,null}},
            "assortment": {{[Prefix]assortment,decimal,null}}
        }
        ]]>
    </Subtemplate>
	<FirstRow>
		<![CDATA[
        "totalCount": {{TotalCount,int,null}},
        {{Template: Product}},
        {{Template: PointOfSale}},
        {{Subtemplate: Expressions, Total}}
	]]>
	</FirstRow>
	<Rows>
		<![CDATA[
        {
            "totalCount": {{TotalCount,int,null}},
            {{Template: Product}},
		    {{Template: PointOfSale}},
            {{Subtemplate: Expressions}}
        }
	]]>
	</Rows>
	<Result>
		<![CDATA[
        {
	        "Totals": 
            {
		        {{FirstRow}}
	        },
	        "PaginatedResult": 
            {
		        "TotalResults": {{PaginatedTotalRows}},
		        "First": {{PaginatedFirstRow}},
		        "Size": {{PaginatedSize}},
		        "CurrentResults": {{PaginatedCountRows}},
		        "CurrentResultsSelectables": {{PaginatedCountRows}},
		        "AnyRow": {{PaginatedAnyRows}},
		        "NextPageFirst": {{PaginatedNewFirstRow}},
		        "Rows": 
                    [
		                {{Rows}}
		            ]
	        }
        }
		]]>
	</Result>
</Template>